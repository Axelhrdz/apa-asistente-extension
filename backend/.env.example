PORT=3000
NODE_ENV=development
# Optional: restrict browser origins (web app). Extension calls always allow
# chrome-extension://… in app.js. Example:
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB (Atlas SRV or local)
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB_NAME=apa_asistente
# MONGO_COLLECTION_ACCOUNTS=accounts_rec_banios
# MONGO_COLLECTION_RECIBOS=recibos_agua_2025
# Multiple yearly collections are supported (comma-separated):
# MONGO_COLLECTION_RECIBOS=recibos_agua_2025,recibos_agua_2024
