PORT=3001
NODE_ENV=production

# Same host/user as ~/mern-hosting-setup/stack (Docker service name: mongo, port 27017)
# Example:
# MONGODB_URI=mongodb://admin:YOUR_MONGO_ROOT_PASSWORD@mongo:27017/apa_asistente_extension?authSource=admin
MONGODB_URI=

MONGO_DB_NAME=apa_asistente_extension
MONGO_COLLECTION_ACCOUNTS=accounts_rec_banios
# Comma-separated: API merges recibos from every listed collection (all years).
MONGO_COLLECTION_RECIBOS=recibos_agua_2026,recibos_agua_2025,recibos_agua_2024,recibos_agua_2023,recibos_agua_2022

# Web UIs + tunnel (optional). Extension always allows chrome-extension:// origins in code.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://apa-asistente.site
