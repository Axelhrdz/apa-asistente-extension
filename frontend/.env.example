# Base URL for the extension API (through Caddy). No trailing slash.
# Same machine as Vite:
VITE_EXTENSION_API_BASE=http://127.0.0.1:8080/extension-api
# From another PC on the LAN, use the server IP and ensure backend ALLOWED_ORIGINS includes your Vite origin, e.g.:
# VITE_EXTENSION_API_BASE=http://192.168.1.50:8080/extension-api
