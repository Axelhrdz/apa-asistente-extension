{
  "name": "apa-asistente",
  "version": "0.1.0",
  "private": true,
  "description": "APA Asistente — Chrome extension + Express API",
  "workspaces": [
    "backend",
    "extension",
    "frontend"
  ],
  "scripts": {
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w frontend",
    "start": "npm run start -w backend",
    "start:api": "npm run start -w backend",
    "import:excel": "npm run import:excel -w backend",
    "pack:extension": "npm run pack -w extension"
  }
}
